<!DOCTYPE html>
<html>
  <head>
    <title>lain</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>
  </head>

  <body class="bg-slate-50 min-h-screen">
    <header class="bg-white border-b border-slate-200">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <%= link_to "lain", items_path, class: "font-bold text-slate-800" %>
        <%= link_to "New item", new_item_path, class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded" %>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
      <% if notice.present? %>
        <div class="mb-6 text-emerald-800 border border-emerald-200 px-4 py-3 rounded">
          <%= notice %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
