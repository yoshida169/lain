<!DOCTYPE html>
<html>
  <head>
    <title>lain</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-h-screen">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <%= link_to items_path, class: "flex items-center gap-2 group" do %>
          <span class="text-xl font-bold text-slate-800 group-hover:text-indigo-600 transition-colors">lain</span>
        <% end %>
        <%= link_to "New item", new_item_path,
              class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
      <% if notice.present? %>
        <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm px-4 py-3 rounded-lg">
          <%= notice %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
