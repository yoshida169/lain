<div id="<%= dom_id item %>">
  <h2 class="text-lg font-semibold mb-1"><%= item.title %></h2>
  <p class="text-slate-600 text-sm line-clamp-3"><%= item.content %></p>
  <% if item.tags.any? %>
    <div class="flex flex-wrap gap-1 mt-2">
      <% item.tags.each do |tag| %>
        <span class="bg-indigo-50 text-indigo-700 text-xs px-2 py-1 rounded"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>
</div>
