<div id="<%= dom_id item %>">
  <h2 class="text-lg font-semibold text-slate-800 mb-1"><%= item.title %></h2>
  <p class="text-slate-600 text-sm leading-relaxed line-clamp-3"><%= item.content %></p>
  <% if item.tags.any? %>
    <div class="flex flex-wrap gap-1.5 mt-3">
      <% item.tags.each do |tag| %>
        <span class="bg-indigo-50 text-indigo-700 text-xs font-medium px-2.5 py-1 rounded-full"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>
</div>
