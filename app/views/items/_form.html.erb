<%= form_with(model: item, class: "space-y-4") do |form| %>
  <% if item.errors.any? %>
    <div class="border border-red-200 text-red-800 text-sm px-4 py-3 rounded">
      <p class="font-medium mb-1"><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</p>
      <ul class="list-disc list-inside">
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_field :title,
          class: "w-full border border-slate-300 rounded px-3 py-2 text-sm",
          placeholder: "Item title" %>
  </div>

  <div>
    <%= form.label :content, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_area :content, rows: 6,
          class: "w-full border border-slate-300 rounded px-3 py-2 text-sm resize-none",
          placeholder: "Write something..." %>
  </div>

  <div>
    <%= form.label :tag_names, "Tags", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_field :tag_names,
          class: "w-full border border-slate-300 rounded px-3 py-2 text-sm",
          placeholder: "ruby, rails, hotwire (comma separated)" %>
  </div>

  <div>
    <%= form.submit class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded cursor-pointer" %>
  </div>
<% end %>
