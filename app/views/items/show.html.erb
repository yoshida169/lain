<div class="bg-white border border-slate-200 rounded-xl p-6">
  <h1 class="text-2xl font-bold text-slate-800 mb-3"><%= @item.title %></h1>
  <p class="text-slate-700 leading-relaxed whitespace-pre-wrap"><%= @item.content %></p>

  <% if @item.tags.any? %>
    <div class="flex flex-wrap gap-1.5 mt-5">
      <% @item.tags.each do |tag| %>
        <span class="bg-indigo-50 text-indigo-700 text-xs font-medium px-2.5 py-1 rounded-full"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>
</div>

<div class="flex items-center justify-between mt-5">
  <div class="flex items-center gap-4">
    <%= link_to "← Back", items_path, class: "text-sm text-slate-500 hover:text-slate-800 font-medium" %>
    <%= link_to "Edit", edit_item_path(@item), class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>
  <%= button_to "Delete", @item, method: :delete,
        class: "text-sm text-red-600 hover:text-red-800 font-medium bg-transparent border-none cursor-pointer",
        data: { turbo_confirm: "Delete this item?" } %>
</div>
