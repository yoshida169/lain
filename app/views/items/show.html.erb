<p style="color: green"><%= notice %></p>

<%= render @item %>

<% if @item.tags.any? %>
  <p>
    <strong>Tags:</strong>
    <% @item.tags.each do |tag| %>
      <span style="display: inline-block; padding: 2px 8px; margin: 2px; border: 1px solid #999; border-radius: 4px; font-size: 0.85em;"><%= tag.name %></span>
    <% end %>
  </p>
<% end %>

<div>
  <%= link_to "Edit this item", edit_item_path(@item) %> |
  <%= link_to "Back to items", items_path %>

  <%= button_to "Destroy this item", @item, method: :delete %>
</div>
