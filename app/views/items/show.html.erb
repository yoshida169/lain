<div class="bg-white border border-slate-200 rounded p-6">
  <h1 class="text-2xl font-bold mb-3"><%= @item.title %></h1>
  <p class="text-slate-700 whitespace-pre-wrap"><%= @item.content %></p>

  <% if @item.tags.any? %>
    <div class="flex flex-wrap gap-1 mt-4">
      <% @item.tags.each do |tag| %>
        <span class="bg-indigo-50 text-indigo-700 text-xs px-2 py-1 rounded"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>
</div>

<div class="flex items-center justify-between mt-4">
  <div class="flex gap-4">
    <%= link_to "← Back", items_path, class: "text-sm text-slate-500" %>
    <%= link_to "Edit", edit_item_path(@item), class: "text-sm text-indigo-600" %>
  </div>
  <%= button_to "Delete", @item, method: :delete,
        class: "text-sm text-red-600 bg-transparent border-none cursor-pointer",
        data: { turbo_confirm: "Delete this item?" } %>
</div>
