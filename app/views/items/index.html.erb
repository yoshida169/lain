<h1 class="text-2xl font-bold mb-6">Items</h1>

<% if @tags.any? %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "All", items_path,
          class: "text-sm px-3 py-1 rounded border #{params[:tag].blank? ? 'bg-indigo-600 text-white border-indigo-600' : 'text-slate-600 border-slate-200'}" %>
    <% @tags.each do |tag| %>
      <%= link_to tag.name, items_path(tag: tag.name),
            class: "text-sm px-3 py-1 rounded border #{Array(params[:tag]).include?(tag.name) ? 'bg-indigo-600 text-white border-indigo-600' : 'text-slate-600 border-slate-200'}" %>
    <% end %>
  </div>
<% end %>

<% if @items.empty? %>
  <div class="text-center py-16 text-slate-400">
    <p>No items yet.</p>
    <p class="text-sm mt-1"><%= link_to "Create your first item", new_item_path, class: "text-indigo-600" %></p>
  </div>
<% else %>
  <div id="items" class="space-y-3">
    <% @items.each do |item| %>
      <div class="bg-white border border-slate-200 rounded p-5">
        <%= render item %>
        <div class="mt-3 pt-3 border-t border-slate-100">
          <%= link_to "View →", item, class: "text-sm text-indigo-600" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
