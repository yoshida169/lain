{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2
	},
  "assist": {
		"actions": {
			"source": {
				"organizeImports": {
					 "level": "on"
				}
			}
		}
  },
	"files": {
		"includes": ["app/frontend/**/*", "e2e/**/*"]
	}
}
