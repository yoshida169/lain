{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2
	},
	"files": {
		"include": ["app/frontend/**/*", "e2e/**/*"]
	}
}
